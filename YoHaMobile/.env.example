# Mode USB (câble + npm run phone) — Django: runserver 127.0.0.1:8000
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000/api/v1

# Mode Wi‑Fi (Expo Go ou dev-client sans câble) — Django: runserver 0.0.0.0:8000
# EXPO_PUBLIC_API_URL=http://192.168.0.231:8000/api/v1

# Push notifications (app fermée / écran éteint) — requis une fois :
#   npm install -g eas-cli && eas login && eas init
# Puis rebuild APK : npx expo run:android
# Configurer FCM dans Expo : https://docs.expo.dev/push-notifications/fcm-credentials/

# OAuth — Google Cloud Console (IDs client OAuth 2.0)
# Web client requis pour Android ; iOS client pour iPhone ; tous les IDs aussi dans backend GOOGLE_OAUTH_CLIENT_IDS
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxx.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=yyyy.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=zzzz.apps.googleusercontent.com
