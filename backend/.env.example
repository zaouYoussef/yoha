# Copier vers .env et adapter — ne jamais committer .env
DJANGO_SETTINGS_MODULE=yoha.settings.development
DJANGO_SECRET_KEY=changez-moi-en-production-min-50-caracteres-aleatoires
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.100
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3002,http://127.0.0.1:3002,http://localhost:3000,http://127.0.0.1:3000
# Mobile Expo Go : remplacez 192.168.1.100 par l'IP LAN de votre PC (ipconfig)
# Les apps natives n'envoient pas d'Origin CORS — seul ALLOWED_HOSTS compte pour l'API directe.

# Base de données (PostgreSQL obligatoire en production)
DATABASE_URL=postgres://yoha:yoha@localhost:5432/yoha

# Redis (cache, rate-limit, sessions)
REDIS_URL=redis://localhost:6379/0

# Chiffrement PII (générer: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FIELD_ENCRYPTION_KEY=

# JWT (optionnel — sinon dérivé de SECRET_KEY en dev)
JWT_SIGNING_KEY=

# OAuth mobile — Google (IDs client séparés par virgule) & Apple (bundle id iOS)
# Ex. GOOGLE_OAUTH_CLIENT_IDS=123.apps.googleusercontent.com,456.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_IDS=
APPLE_CLIENT_ID=ma.yoha.app

# Images — stockage local (dev) ou S3/R2 (production)
# local = fichiers WebP sur disque (backend/media/) | s3 = Cloudflare R2 / AWS S3
MEDIA_STORAGE_BACKEND=local
MEDIA_URL=/media/
# URL publique CDN en production (ex. https://cdn.yoha.ma ou domaine R2)
MEDIA_PUBLIC_BASE_URL=
# Pour S3 / Cloudflare R2 (MEDIA_STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=auto
AWS_S3_ENDPOINT_URL=
AWS_S3_CUSTOM_DOMAIN=

# Sécurité production
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Front (liens suivi dans les e-mails)
YOHA_FRONTEND_URL=http://localhost:3002

# E-mail SMTP — notifications commande (ex. Gmail / SendGrid)
# Laissez EMAIL_HOST vide en dev pour afficher les mails dans la console Django
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=zaoujalyoussef3@gmail.com
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=YouHa <zaoujalyoussef3@gmail.com>

# Livreurs — tous reçoivent l'alerte ; le premier qui confirme dans le dashboard prend la course
YOHA_COURIER_NOTIFY_EMAILS=livreur@yoha.ma,courier2@example.com,courier3@example.com

# Campagnes promo automatiques (lundi & jeudi 10h)
PROMO_SCHEDULER_ENABLED=True
PROMO_SCHEDULER_TIMEZONE=Africa/Casablanca
PROMO_SCHEDULER_HOUR=10
PROMO_SCHEDULER_MINUTE=0
PROMO_CAMPAIGN_MIN_DAYS=2
